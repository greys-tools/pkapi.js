{
  "name": "pkapi.js",
  "version": "7.5.0",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.mjs"
      }
    }
  },
  "dependencies": {
    "@vvo/tzdb": "^6.7.0",
    "axios": "^1.14.0",
    "chrono-node": "^2.4.2",
    "tinycolor2": "^1.4.2",
    "valid-url": "^1.0.9"
  },
  "scripts": {
    "test": "npx jest",
    "check": "npx tsc --noEmit",
    "lint": "npx prettier lib --check",
    "format": "npx prettier lib --write",
    "build": "npx rollup --config",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/greys-tools/pkapi.js.git"
  },
  "keywords": [
    "pluralkit",
    "plural",
    "pk",
    "api"
  ],
  "author": "greysdawn <greysdawn@gmail.com> (https://greysdawn.com)",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/greys-tools/pkapi.js/issues"
  },
  "homepage": "https://github.com/greys-tools/pkapi.js#readme",
  "description": "A JS wrapper for the PluralKit Discord bot's API.",
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^9.0.2",
    "@types/node": "^20.19.7",
    "@types/tinycolor2": "^1.4.3",
    "@types/valid-url": "^1.0.3",
    "esbuild": "^0.28.0",
    "jest": "^30.0.3",
    "prettier": "3.6.2",
    "rollup": "^3.4.0",
    "ts-jest": "^29.4.0",
    "tslib": "^2.4.1",
    "typescript": "^5.8.3"
  }
}
